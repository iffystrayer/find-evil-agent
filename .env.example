# Find Evil Agent Configuration Template
# Copy this file to .env and update with your actual values

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Find Evil Agent
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# SIFT Workstation VM
# ============================================================================
# Update these with your SIFT VM details
SIFT_VM_HOST=192.168.1.100
SIFT_VM_PORT=16789
SIFT_SSH_USER=sansforensics

# SSH key path. Leave UNSET when running via docker compose — the
# compose stack forwards your host SSH agent (SSH_AUTH_SOCK) instead of
# bind-mounting the private key into the container, so asyncssh
# auto-discovers the key from the agent. Set this only for bare-metal
# runs that need an explicit key file.
# SIFT_SSH_KEY_PATH=/home/user/.ssh/id_rsa

# SSH host-key verification (defends against MITM).
# Default: enabled, uses ~/.ssh/known_hosts. Run once before first connect:
#   ssh-keyscan -p $SIFT_VM_PORT $SIFT_VM_HOST >> ~/.ssh/known_hosts
# To use a dedicated trust store, point at it here:
# SSH_KNOWN_HOSTS_PATH=/etc/find-evil-agent/sift_known_hosts
# Set to false ONLY in transitional dev environments — disables host-key
# verification entirely and exposes the connection to MITM attacks.
SSH_STRICT_HOST_KEY_CHECKING=true

# ============================================================================
# MCP Server
# ============================================================================
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=16790

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Supported providers: ollama, openai, anthropic
LLM_PROVIDER=ollama
LLM_MODEL_NAME=gemma4:31b-cloud
LLM_TEMPERATURE=0.1

# Ollama Server (update with your Ollama host)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (optional - required if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Anthropic (optional - required if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# Tool Selection Settings
# ============================================================================
TOOL_CONFIDENCE_THRESHOLD=0.7
SEMANTIC_SEARCH_TOP_K=10

# ============================================================================
# Security
# ============================================================================
MAX_TOOL_TIMEOUT=3600
DEFAULT_TOOL_TIMEOUT=60

# ============================================================================
# Observability - Langfuse (Optional)
# ============================================================================
# Get your keys from https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=http://localhost:33000
LANGFUSE_ENABLED=false

# ============================================================================
# API Server
# ============================================================================
# Comma-separated list of allowed CORS origins for frontend
# API_CORS_ORIGINS=http://localhost:15173,http://127.0.0.1:15173

# API key authentication (A4). Comma-separated list of accepted keys.
# Leave UNSET / empty for local-dev no-auth mode (a warning is logged).
# Generate keys with `python -c 'import secrets; print(secrets.token_urlsafe(32))'`.
# API_KEYS=key1,key2

# ============================================================================
# Reporting
# ============================================================================
DEFAULT_REPORT_FORMAT=markdown
REPORT_OUTPUT_DIR=./reports
